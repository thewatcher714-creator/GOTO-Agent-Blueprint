{
  "entities": {
    "media": {
      "title": "Media Item",
      "description": "Site media assets including images and YouTube entries",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "youtube"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "altText": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "embedUrl": { "type": "string" },
        "pageTarget": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "category", "isActive"]
    },
    "downloads": {
      "title": "Download Item",
      "description": "Client downloadable resources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "fileType": { "type": "string" },
        "fileUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "buttonLabel": { "type": "string" },
        "sortOrder": { "type": "integer" },
        "visibility": { "type": "string", "enum": ["public", "private", "gated"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "fileUrl", "visibility", "isActive"]
    },
    "reportTemplates": {
      "title": "Report Template",
      "description": "Reusable HTML report layouts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "htmlBody": { "type": "string" },
        "cssBlock": { "type": "string" },
        "previewImageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "htmlBody", "status"]
    },
    "reports": {
      "title": "Report",
      "description": "Client-specific reports generated from templates",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "templateId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "final"] },
        "htmlOutput": { "type": "string" },
        "mergeFields": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientName", "clientEmail", "templateId", "status", "htmlOutput"]
    },
    "emailTemplates": {
      "title": "Email Template",
      "description": "Reusable HTML email layouts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "htmlBody": { "type": "string" },
        "plainText": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "subject", "htmlBody", "status"]
    }
  },
  "firestore": {
    "/media": {
      "schema": "media",
      "description": "Site media assets"
    },
    "/downloads": {
      "schema": "downloads",
      "description": "Client downloadable files"
    },
    "/reportTemplates": {
      "schema": "reportTemplates",
      "description": "Reusable report templates"
    },
    "/reports": {
      "schema": "reports",
      "description": "Generated client reports"
    },
    "/emailTemplates": {
      "schema": "emailTemplates",
      "description": "Reusable email templates"
    }
  }
}
